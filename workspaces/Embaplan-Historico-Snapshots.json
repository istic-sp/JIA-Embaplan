            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [3456, 2832],
      "id": "308e2bca-fe36-4060-9683-5cd7fe7b2e9c",
      "name": "Config"
    },
    {
      "parameters": {
        "jsCode": "// Achata o SUMARIO_PRE_CALCULADO em linhas de snapshot (1 por anúncio).\n// Aceita o body tanto em $json.body (webhook) quanto direto em $json.\nconst src = $('Webhook Capture').first().json;\nconst body = src.body || src;\n\nconst periodo = body.periodo || null;\nconst rotulo = body.rotulo || null;\nconst arquivo_nome = body.arquivo_nome || null;\nconst user_id = body.user_id || null;\n\n// GUARDA: periodo obrigatória.\nif (!periodo) {\n  throw new Error('periodo ausente na captura — data de referência obrigatória.');\n}\n\nconst produtos = Array.isArray(body.produtos) ? body.produtos : [];\n\nfunction extrairLoja(p) {\n  if (p.loja) return String(p.loja);\n  const nome = String(p.produto || '');\n  const m = nome.match(/\\[?\\(?\\s*Loja\\s*([0-9A-Za-z]+)\\s*\\)?\\]?/i);\n  return m ? `Loja ${m[1]}` : null;\n}\n\nfunction num(v) {\n  if (v === null || v === undefined || v === '') return null;\n  const n = Number(String(v).replace(/[^0-9.,-]/g, '').replace(/\\.(?=\\d{3}(\\D|$))/g, '').replace(',', '.'));\n  return Number.isFinite(n) ? n : null;\n}\n\n// Pega o 'Link do Shopee' já gerado pelo sub-fluxo (mesma lógica do chat).\nfunction extrairLink(a) {\n  if (!a) return null;\n  const cand = a['Link do Shopee'] ?? a['link_shopee'] ?? a['linkShopee'] ?? a['link'] ?? a['url'] ?? a['permalink'] ?? (a._metricas && (a._metricas.link || a._metricas['Link do Shopee'])) ?? null;\n  const s = (cand === null || cand === undefined) ? '' : String(cand).trim();\n  return s.length > 0 ? s : null;\n}\n\nconst rows = [];\nfor (const p of produtos) {\n  const loja = extrairLoja(p);\n  const det = Array.isArray(p.anuncios_detalhados) ? p.anuncios_detalhados : [];\n  for (const a of det) {\n    const m = a._metricas || a;\n    const indice = a.indice ?? a.id_anuncio ?? a.id ?? null;\n    if (indice === null || indice === undefined || indice === '') continue;\n    const link = extrairLink(a);\n    rows.push({\n      loja,\n      produto: p.produto ?? null,\n      anuncio_indice: String(indice),\n      titulo: a.titulo ?? a.nome ?? null,\n      status: m.status ?? a.status ?? null,\n      saude: num(p.saude_0_10),\n      vendas: num(m.vendas ?? a.vendas),\n      receita: num(m.receita ?? a.receita),\n      lucro: num(m.lucro ?? a.lucro),\n      investimento_ads: num(m.custo_ads ?? m.investimento_ads ?? a.custo_ads),\n      acos: num(m.acos_pct ?? a.acos_pct),\n      ctr: num(m.ctr_pct ?? a.ctr_pct),\n      conversao: num(m.conversao_pct ?? a.conversao_pct),\n      roas: num(m.roas ?? a.roas),\n      roi: num(m.roi_ads_pct ?? a.roi_ads_pct),\n      margem_liquida: num(m.margem_liquida_pct ?? a.margem_liquida_pct),\n      ticket_medio: num(p.ticket_medio),\n      link,\n      metrics: Object.assign({}, m, { link, 'Link do Shopee': link })\n    });\n  }\n}\n\nif (rows.length === 0) {\n  const nProd = produtos.length;\n  const totalDet = produtos.reduce((s, p) => s + (Array.isArray(p.anuncios_detalhados) ? p.anuncios_detalhados.length : 0), 0);\n  throw new Error('Nenhum anúncio encontrado para capturar (produtos=' + nProd + ', anuncios_detalhados=' + totalDet + '). Se produtos=0, a planilha foi lida vazia (sincronização do Google Sheets) — reenvie. Caso contrário, verifique as colunas indice/ID do Anúncio no SUMARIO_PRE_CALCULADO.');\n}\n\nreturn [{\n  json: {\n    SUPABASE_URL: $('Config').first().json.SUPABASE_URL,\n    periodo: body.periodo ?? null,\n    rotulo: body.rotulo ?? null,\n    arquivo_nome: body.arquivo_nome ?? null,\n    user_id: body.user_id ?? null,\n    rows\n  }\n}];"
      },
